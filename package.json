{
  "name": "hh-unified-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:safe": "ulimit -n 10240 2>/dev/null; next dev -p 3000",
    "clean": "rm -rf .next .next-dev node_modules/.cache",
    "build": "next build",
    "build:clean": "npm run clean && npm run build",
    "start": "next start",
    "lint": "next lint",
    "lint:ci": "eslint \"src/__tests__/**/*.{ts,tsx}\" --max-warnings 0",
    "check:migration-filenames": "node scripts/check-migration-filenames.mjs",
    "check:migration-order": "node scripts/check-migration-order.mjs",
    "check:schema-preflight": "node scripts/check-schema-preflight.mjs",
    "check:schema-preflight:strict": "SCHEMA_PREFLIGHT_RLS_MODE=strict node scripts/check-schema-preflight.mjs",
    "check:schema-vs-code": "node scripts/audit-schema-vs-code.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:check:ci": "prettier --check \".github/workflows/**/*.yml\" \"docs/**/*.md\" \"README.md\" \"package.json\" \"tsconfig.json\" \"vitest.config.ts\" \"playwright.config.ts\" \".eslintrc.json\" \".prettierrc.json\" \"next.config.mjs\" \"src/**\"",
    "test": "NODE_ENV=test vitest",
    "test:unit": "NODE_ENV=test vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project chromium",
    "test:local": "CI= E2E_WORKER_NAME='[E2E] Seed Worker' npx playwright test --project=chromium --project=chromium-payments --project=chromium-delete-mutations",
    "test:local:ui-only": "CI= npx playwright test --project=chromium",
    "test:before-push": "npx prettier --write . && CI= E2E_BASE_URL='http://localhost:3000' npx playwright test --project=chromium && node scripts/guard-no-test-data-push.mjs && git push origin main",
    "test:e2e:company-profile": "CI= playwright test tests/settings-company-profile.spec.ts --project=chromium",
    "test:e2e:document-header": "CI= playwright test tests/settings-company-profile.spec.ts -g \"invoice print header\" --project=chromium",
    "test:e2e:company-branding": "CI= playwright test tests/settings-company-profile.spec.ts --project=chromium",
    "test:e2e:delete": "playwright test tests/delete-flows.spec.ts tests/delete-flows-mutations.spec.ts",
    "test:e2e:delete-catalog": "playwright test tests/delete-all-surfaces.spec.ts",
    "test:e2e:integration": "playwright test tests/integration-data-flow.spec.ts",
    "test:e2e:quick-expense": "CI= playwright test tests/quick-expense-upload.spec.ts --project=chromium",
    "test:e2e:payment-receipt": "E2E_ALLOW_PAYMENT_MUTATIONS=1 playwright test tests/worker-payment-receipt.spec.ts",
    "test:e2e:payment-full-flow": "E2E_ALLOW_PAYMENT_MUTATIONS=1 playwright test tests/worker-payment-full-flow.spec.ts",
    "test:e2e:commission-full-flow": "CI= playwright test tests/commissions-full-flow.spec.ts --project=chromium --reporter=line,html",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ui-mutations": "E2E_ALLOW_PAYMENT_MUTATIONS=1 playwright test --ui",
    "test:e2e:install": "playwright install",
    "test:e2e:install:ci": "playwright install --with-deps chromium",
    "ui:test": "npx tsx tests/ui-tests.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "db:seed:clean": "npx tsx scripts/cleanup-test-data.ts",
    "db:seed:clean:test": "NODE_ENV=test npx tsx scripts/cleanup-test-data.ts",
    "db:reset:test": "NODE_ENV=test npx tsx scripts/cleanup-test-data.ts",
    "db:ensure-tables": "npx tsx scripts/ensure-project-tasks.ts",
    "db:migrate": "npx supabase db push",
    "db:seed": "npx supabase db reset --local",
    "db:seed:remote": "node scripts/seed-supabase-remote.mjs",
    "db:seed:e2e": "npx tsx scripts/ensure-e2e-seed.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "html2pdf.js": "^0.14.0",
    "isomorphic-dompurify": "^3.5.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "react": "^18",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18",
    "react-hot-toast": "^2.5.2",
    "react-zoom-pan-pinch": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "puppeteer": "^24.37.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
