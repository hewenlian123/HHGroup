{
  // Next.js 应用主配置。若已存在本文件，勿再运行 `npx tsc --init`（会报 TS5054）。
  // Node/脚本专用、接近 `tsc --init` 的严格选项见 `tsconfig.node.json`，运行：`npm run typecheck:node`
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "downlevelIteration": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next-dev/types/**/*.ts",
    ".next-e2e/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
