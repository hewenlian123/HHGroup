# Copy to `.env.test` for local E2E / Playwright. Prefer `http://127.0.0.1:54321` — never production.
#
# Load order (last wins): `.env` → `.env.local` → `.env.e2e` (optional) → `.env.test`
# So `.env.test` overrides a production `NEXT_PUBLIC_SUPABASE_URL` in `.env.local`.
# `playwright.config.ts` loads `.env.test` again explicitly after the chain.
#
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Playwright only: set to 0 to force spawning `next dev` with the env above (stop any other server on E2E_BASE_URL first).
# Default reuse of an existing dev server can hide SUPABASE_SERVICE_ROLE_KEY so `/api/upload-receipt/options` stays on anon + RLS.
# When Playwright spawns the dev server, it waits up to 300s for `E2E_BASE_URL/financial/expenses` (see `playwright.config.ts` webServer).
# E2E_PLAYWRIGHT_REUSE_DEV_SERVER=0

# Debug: GET /api/diag/upload-receipt-supabase (canonical). Also /api/_diag/upload-receipt-supabase → rewrite.
# `next dev`: NODE_ENV=development — returns JSON. `next start` with NODE_ENV=production: set E2E_DIAG_UPLOAD_RECEIPT_SUPABASE=1.
# Compare NEXT_PUBLIC_SUPABASE_URL host + service-role presence + workers count vs Playwright `.env.test`.

# Optional: direct Postgres for migrations / schema repair
# SUPABASE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Other scripts (`tests/e2e-cleanup-db.ts`, `scripts/ensure-e2e-seed.ts`) still honor
# E2E_ALLOW_REMOTE_SUPABASE=1 for intentional hosted DB mutations. Playwright globalSetup
# always throws if NEXT_PUBLIC_SUPABASE_URL contains `supabase.co`.
